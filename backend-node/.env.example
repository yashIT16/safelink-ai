# SafeLink AI — Environment Variables
# ─────────────────────────────────────
# Copy this file to .env and fill in real API keys

# ── Node.js Backend ──────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Flask ML API ─────────────────────────────────────
FLASK_API_URL=http://localhost:5001

# ── Google Safe Browsing API ─────────────────────────
# Get key: https://developers.google.com/safe-browsing/v4/get-started
# Leave empty to use mock responses
GOOGLE_SAFE_BROWSING_KEY=

# ── PhishTank API ────────────────────────────────────
# Register: https://www.phishtank.com/api_register.php
# Leave empty to use mock responses
PHISHTANK_API_KEY=
