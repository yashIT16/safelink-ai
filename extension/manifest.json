{
  "manifest_version": 3,
  "name": "SafeLink AI",
  "version": "1.0.0",
  "update_url": "https://raw.githubusercontent.com/yashIT16/safelink-ai/master/updates.xml",
  "description": "AI-powered phishing and malware protection. Real-time URL scanning with machine learning.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SafeLink AI - Click to scan"
  },

  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_start"
    }
  ],

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "downloads",
    "notifications",
    "webNavigation",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],

  "host_permissions": [
    "http://localhost:3001/*",
    "https://localhost:3001/*",
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": ["content/content.css", "blocked.html", "blocked-file.html"],
      "matches": ["<all_urls>"]
    }
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
